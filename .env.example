GITCODE_TOKEN=your_gitcode_personal_access_token
GITCODE_API_BASE=https://api.gitcode.com/api/v5

# Auto sync local repository for context search
LOCAL_REPO_ROOT=repos
# Optional: override full local path
# LOCAL_REPO_PATH=/path/to/repos/Owner/myrepo
# Optional: override remote URL
# REPO_REMOTE_URL=https://gitcode.com/Owner/myrepo.git

# Optional: only needed when --backend api or --backend local
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=your_llm_api_key        # 本地模型可留空或填任意字符串
LLM_MODEL=gpt-4o-mini               # local 后端填本地模型名，如 qwen2.5-7b-instruct
LLM_REQUEST_TIMEOUT=120             # api 后端单次请求超时（秒）

# --backend local 专用（本地小模型并发批次）
LOCAL_BATCH_CHARS=6000              # 每批 diff 字符上限，根据模型 context window 调整
LOCAL_MAX_WORKERS=4                 # 并发请求数，不超过模型服务并发上限
LOCAL_REQUEST_TIMEOUT=180           # 每次请求超时（秒）

# Diff budget controls
MAX_PATCH_CHARS=40000
MAX_FILES_IN_DIFF=25
MAX_HUNKS_PER_FILE=4
MAX_CHARS_PER_FILE=5000

# Second-pass (deep expand on top-risk files)
SECOND_PASS_FOCUS_FILES=6
SECOND_PASS_HUNKS_PER_FILE=10
SECOND_PASS_CHARS_PER_FILE=12000

# Output controls
CHANGED_FILE_LIST_LIMIT=120
MAX_LINE_CANDIDATES=120
MAX_CANDIDATES_IN_PROMPT=40
ENABLE_LINE_CANDIDATES=false

# Line number reference table controls
DIFF_LINE_REF_MAX_FILES=10
DIFF_LINE_REF_MAX_LINES=300

# Incremental review cache
INCREMENTAL_REVIEW=true
CACHE_DIR=.review_cache
# 缓存文件超过此天数自动删除（0=不清理）
CACHE_MAX_AGE_DAYS=90
# 本地克隆超过此天数未使用自动删除（0=不清理，谨慎开启）
REPO_MAX_AGE_DAYS=0
